# Inbuilt function definitions
# Syntax:
#   name(Type, ...) -> ReturnType
#   Any   : accepts any BBC value (no type restriction)
#   *     : suffix on the last param type — variadic (zero or more occurrences)
#   ~     : suffix on return type — propagate errors from args (returns !ReturnType
#           if any argument carries an error union, Void otherwise)
#
# Supported base types: Int Float Bool Char String Void Any

print(Any*) -> Void~
println(Any*) -> Void~
input(String) -> String
read(String) -> String~