import("bbc-lib/Strings.bbc")

func reduceDoubleSpace(String s) String {
    let ret = ""
    let accu = true
    for c: stringIterator(s) 
        ret = if c == ' ' && accu {
            accu = false
            ret + c
        } elif c != ' ' {
            accu = true
            ret + c
        } else 
            ret

    ret
}

func main() Int {
    let a = read("test.bbc")
    let b = reduceDoubleSpace(a)
    for c: stringIterator(b) 
        if c != '\n' && c != '\t' && c != '\r'
            print(c)

    println('')
    1
}
