import("import_file.bbc") as import_file



trait Stringable(Type) {
    func toString () String

    func with (Type other) String
}

implement Stringable: import_file.Toto {
    func toString() String {
        "(a, b)"
    }

    func with (import_file.Toto other) String {
        "(a, b)(a', b')"
    }
}


func <Type: Stringable, Type2: Add> test (Type x, Type2 y) Void {
    println(x.toString())
    println(y)
}


func main() Int {
    let first = @import_file.Toto{
        a = 1,
        b = 2
    }

    let second = @import_file.Toto{
        a = 3,
        b = 4
    }
    test(first, 1)
    println(import_file.test(8))
    1
}
