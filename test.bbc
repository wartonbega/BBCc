struct Toto {
    Int a,
    Int b
}


trait Stringable(Type) {
    func toString () String

    func with (Type other) String
}

implement Stringable: Toto {
    func toString() String {
        "(a, b)"
    }

    func with (Toto other) String {
        "(a, b)(a', b')"
    }
}


func <Type: Stringable> test (Type x, Type y) Void {
    println(x.toString())
    println(x.with(y))
}


func main() Int {
    let first = @Toto{
        a = 1,
        b = 2
    }

    let second = @Toto{
        a = 3,
        b = 4
    }
    
    1
}
