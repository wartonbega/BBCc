struct Test {
    Int a,
    Int b
}

struct Toto {
    Int a,
    Test b
}

// Fibonnaci recursive
func fibRec2(Int x) Int {
    let ret = if x == 0 0
        elif x == 1 1
        else fibRec2(x - 1) + fibRec2(x - 2)
    ret
}


// Fibonnaci iterative
func fib(Int x) Int {
    let a = 0
    let b = 1
    while x > 0 { 
        let c = a + b
        b = a
        a = c
        x = x - 1
    }
    a
}

func main() Int {
    let b = @Test{
        a = 1,
        b = 2
    }
    
    b.b
}
